<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions for local socket connections and WiFi Direct -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Peer discovery location requirements -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Calling requirements -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Android 13+ Bluetooth & Wifi P2P nearby device searching requirements -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" 
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="tiramisu" />

    <!-- Notification requirements -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground services and target API 34 mapping permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Storage permissions for older devices -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" tools:ignore="ScopedStorage" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/wife"
        android:label="@string/app_name"
        android:roundIcon="@drawable/wife"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">

        <!-- Splash Launcher Screen -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MyApplication">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".MainActivity" android:exported="false" />
        <activity android:name=".DeviceDiscoveryActivity" android:exported="false" />
        <activity android:name=".ChatActivity" android:exported="false" />
        <activity android:name=".VoiceCallActivity" android:exported="false" />
        <activity android:name=".VideoCallActivity" android:exported="false" />
        <activity android:name=".FileTransferActivity" android:exported="false" />
        <activity android:name=".SettingsActivity" android:exported="false" />
        <activity android:name=".CallHistoryActivity" android:exported="false" />
        <activity android:name=".ConnectionStatusActivity" android:exported="false" />

        <!-- Foreground background Services declarations -->
        <service 
            android:name=".ConnectionForegroundService" 
            android:foregroundServiceType="dataSync"
            android:exported="false" />
        
        <service 
            android:name=".VoiceCallForegroundService" 
            android:foregroundServiceType="microphone"
            android:exported="false" />
            
        <service 
            android:name=".VideoCallForegroundService" 
            android:foregroundServiceType="camera"
            android:exported="false" />
            
        <service 
            android:name=".FileTransferForegroundService" 
            android:foregroundServiceType="dataSync"
            android:exported="false" />

    </application>

</manifest>